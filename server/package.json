{
  "name": "@momentum/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:codes": "tsx scripts/seed-access-codes.ts",
    "seed:founders": "tsx scripts/seed-founders.ts",
    "backfill:founder-timezones": "tsx scripts/backfill-founder-timezones.ts"
  },
  "dependencies": {
    "@momentum/shared": "workspace:*",
    "argon2": "0.41.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.1",
    "jose": "5.9.6",
    "undici": "7.1.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.7",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "22.10.1",
    "tsx": "4.19.2",
    "typescript": "5.5.4"
  }
}
