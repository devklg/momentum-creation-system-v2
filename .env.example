# Momentum Creation System v2 — environment template
# Copy to .env (untracked) and fill values for local dev.
# Never commit a real .env.

# ============================================================
# RUNTIME
# NODE_ENV is security-load-bearing: 'production' turns on secure/domain-scoped
# cookies and (per the P10 deployment plan) stricter secret/webhook assertions.
# Validated in server/src/env.ts (enum development|production|test, default development).
# ============================================================
NODE_ENV=development

# ============================================================
# PORTS (locked in PORT-REGISTRY.md — do not change without updating registry)
# ============================================================
SERVER_PORT=7700
COM_PORT=7701
TEAM_PORT=7702
ADMIN_PORT=7703

# ============================================================
# APP PERSISTENCE
# Runtime persistence is direct-only. External MCP tooling for agents and
# operator scripts is not an app runtime persistence edge, so no tool-server
# URL belongs in this app env file.
#
# DIRECT APP PERSISTENCE (ACR-0007 + ACR-0009)
# The MCS app writes directly to its dedicated MongoDB, Neo4j, and ChromaDB
# stack through server-side adapters. Chroma direct mode requires the local GPU
# embedder; there is no CPU fallback.
# ============================================================
MONGODB_URI=mongodb://127.0.0.1:30000
MONGODB_DB=momentum
NEO4J_URI=bolt://127.0.0.1:7710
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
CHROMA_URL=http://localhost:8200
GPU_EMBEDDER_URL=http://localhost:8300
PERSISTENCE_DIRECT_ENABLED=true
PERSISTENCE_MONGO_MODE=direct
PERSISTENCE_NEO4J_MODE=direct
PERSISTENCE_CHROMA_MODE=direct
GPU_EMBEDDER_REQUIRED=true

# ============================================================
# CONTEXT MANAGER / KNOWLEDGE BASE
# Default OFF keeps Michael in the legacy degraded safe-fallback packet path.
# Set true after the app persistence stack is running to let Michael's runtime
# Context Manager pull Kevin-approved knowledge in real time.
# ============================================================
MCS_CONTEXT_MANAGER_LIVE_ENABLED=false

# ============================================================
# ADMIN BA-ID GATE (Chat #85 + #89 lock, Chat #102 TM BA ID lock)
# Comma-separated list of TM BA IDs allowed into apps/admin.
# TM BA ID is the canonical login identifier per Chat #102 (THREE BA ID
# and email are tracked on the BA record but never authenticate).
# Replace with real TM BA IDs in your local .env (never commit real values).
# Example shape only — these are placeholders, not real IDs:
# ============================================================
ADMIN_TMAG_IDS=TMAG-FOUNDER-EXAMPLE-1,TMAG-FOUNDER-EXAMPLE-2

# ============================================================
# AUTH (JWT for .team and admin sessions)
# Set JWT_SECRET to a long random string in real .env. Cookie scoped to .teammagnificent.team
# so the JWT propagates from apps/team to admin.teammagnificent.team.
# ============================================================
JWT_SECRET=replace-me-with-a-long-random-string
JWT_COOKIE_DOMAIN=.teammagnificent.team
JWT_COOKIE_NAME=mcs_session
JWT_TTL_REMEMBER_DAYS=30

# ============================================================
# DOMAINS (production)
# ============================================================
COM_PUBLIC_URL=https://teammagnificent.com
TEAM_PUBLIC_URL=https://teammagnificent.team
ADMIN_PUBLIC_URL=https://admin.teammagnificent.team

# Base URL minted /p/{token} prospect links are built on (#145/#147). Dev
# leaves this unset → defaults to http://localhost:7701 (the local .com app)
# so minted links resolve without a deploy. PRODUCTION MUST set it to the
# public .com domain (no trailing slash) or every minted link points at
# localhost. Was hardcoded in domain/invitations.ts through #144.
PROSPECT_BASE_URL=https://teammagnificent.com

# ============================================================
# CORS — server accepts requests from these three origins
# ============================================================
CORS_ORIGINS=http://localhost:7701,http://localhost:7702,http://localhost:7703,https://teammagnificent.com,https://teammagnificent.team,https://admin.teammagnificent.team

# ============================================================
# COMMUNICATION (Phase 1+ — not used in Phase 0)
# ============================================================
# Telnyx v2 Bearer token. Required for Michael outbound calls.
# Mission Control Portal > Auth > API Keys.
TELNYX_API_KEY=

# Base64-encoded Ed25519 public key from Telnyx Mission Control Portal.
# Webhook signatures are verified against this key. Leave empty in dev to
# bypass signature verification (timestamp replay window still enforced).
TELNYX_PUBLIC_KEY=

# Telnyx Call Control Application connection_id. The app's webhook URL
# should point at /api/telnyx/webhook on this server.
# Mission Control Portal > Call Control > Applications.
TELNYX_CONNECTION_ID=

# Caller ID for Michael's outbound calls. E.164 format (e.g. +13235551234).
# Must be a number assigned to the Call Control Application above.
TELNYX_FROM_NUMBER=

# VM dialer Call Control caller ID. Do not reuse Kevin's separate personal
# live-transfer dialer wiring here.
TELNYX_DIAL_FROM_NUMBER=+13236931362

# Optional per-call webhook URL override. If set, every dial request includes
# this URL so events route here regardless of portal config. Useful with
# ngrok in dev. Leave empty in production once the portal is configured.
TELNYX_WEBHOOK_URL=

EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=webinars@teammagnificent.com
EMAIL_REPLY_TO=

# ============================================================
# ANTHROPIC (Chat #122 — LLM-backed invitation front doors)
# ScriptMaker + Ivory call the Anthropic Messages API DIRECTLY. Get the key
# from console.anthropic.com >
# API Keys. DORMANT until set: empty key => the LLM service throws
# AnthropicConfigError and the surface falls back to the manual compose form,
# rather than crashing boot (same dormant pattern as EMAIL_API_KEY).
# Never commit a real key.
# ANTHROPIC_MODEL is a config constant so a model swap is a one-line change.
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ============================================================
# VOICEBOX (internal .team browser voice output)
# Server-side only, default OFF. This is for Steve/Michael/Ivory browser
# audio generation through VoiceBox; it is not Telnyx/PSTN, not prospect-facing,
# and not an external MCP runtime dependency.
# ============================================================
VOICEBOX_RUNTIME_ENABLED=false
VOICEBOX_BASE_URL=http://127.0.0.1:17493
VOICEBOX_CLIENT_ID=mcs-v2
VOICEBOX_REQUEST_TIMEOUT_MS=30000
VOICEBOX_STEVE_PROFILE_ID=
VOICEBOX_MICHAEL_PROFILE_ID=
VOICEBOX_IVORY_PROFILE_ID=

# ============================================================
# WEBINAR (Chat #116 — Mon/Thu 5pm Pacific, 60 min, recurring Zoom)
# Single persistent Zoom registration link for all sessions. Prospect
# registers through Zoom; Zoom issues their own join link. Seeded onto
# each webinar_event as zoomUrl by `pnpm seed:webinar-events`. A future
# Zoom Server-to-Server OAuth sync agent may overwrite individual events
# with per-occurrence links.
# ============================================================
WEBINAR_REGISTER_URL=

# ============================================================
# VM CAMPAIGN PROVIDER (validated in server/src/env.ts)
# Delivery is dry-run / manual-CSV by default. LIVE voicemail/SMS/email sends
# require BOTH VM_LIVE_DELIVERY_ENABLED=true AND the campaign document carrying
# adminApprovedForLiveDelivery=true. Leave OFF unless a campaign is explicitly
# approved. VM_WEBHOOK_SHARED_SECRET should be set in production so inbound
# provider webhooks are authenticated (empty = check skipped).
# ============================================================
# manual_csv | acquisition_provider_placeholder | telnyx_call_control
VM_PROVIDER_MODE=manual_csv
VM_LIVE_DELIVERY_ENABLED=false
VM_DELIVERY_RATE_PER_MINUTE=60
VM_WEBHOOK_SHARED_SECRET=
# VM_ACQUISITION_PROVIDER_API_URL=   # optional; only when VM_PROVIDER_MODE=acquisition_provider_placeholder
VM_ACQUISITION_PROVIDER_API_KEY=

# ============================================================
# PRODUCTION HEALTH PROBE
# Systemd timer on the VPS runs ops/health-probe.sh every 15 minutes.
# Set a long random value in /opt/mcs-v2/.env; the script sends it as
# x-mcs-health-secret to GET /api/admin/health/triple-stack.
# ============================================================
HEALTH_PROBE_SHARED_SECRET=
HEALTH_STATUS_PATH=/opt/mcs-v2/ops/health-status.json
HEALTH_ALERT_STATE_PATH=/opt/mcs-v2/ops/health-alert-state.json

# ============================================================
# DIRECTLY-READ ENV (not in the Zod schema — read via process.env in code)
# Documented here for discoverability. P10.3 flags consolidating these into
# server/src/env.ts. All are optional; empty/unset is a safe default.
#   DEBUG_ENV               — any truthy value logs env loader diagnostics (env.ts)
#   PUBLIC_ORIGIN           — absolute origin for OG/social-card URLs (middleware/og-injection.ts)
#   STEVE_WORKER_SECRET     — shared secret guarding the Steve worker route (routes/steve.ts)
# Michael runtime three-axis kill switch (config/michaelRuntimeFlags.ts) —
# independent, default-OFF, fail-closed; ONLY the exact string "true" enables an
# axis. Do NOT enable without approval.
#   MICHAEL_RUNTIME_ROUTE_ENABLED
#   MICHAEL_RUNTIME_RESPONSE_ENABLED
#   MICHAEL_RUNTIME_TRACE_ENABLED
# NOTE: FOUNDER_PASSWORD is intentionally NOT here — it is a transient var set
# only while running `setup-founder-access`, then unset; never a persisted .env value.
# ============================================================
