{
  "name": "momentum-creation-system-v2",
  "private": true,
  "version": "0.0.0",
  "description": "Team Magnificent Marketing Momentum Creation System — three clients (.com prospect-facing, .team BA-facing, admin Kevin-only), one server, direct persistence.",
  "author": "Kevin L. Gardner",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "ensure:gpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-gpu-service.ps1",
    "dev": "pnpm ensure:gpu && pnpm --parallel --filter @momentum/team --filter @momentum/server dev",
    "dev:server": "pnpm ensure:gpu && pnpm --filter @momentum/server dev",
    "dev:com": "pnpm ensure:gpu && pnpm --filter @momentum/com dev",
    "dev:team": "pnpm ensure:gpu && pnpm --filter @momentum/team dev",
    "dev:admin": "pnpm ensure:gpu && pnpm --filter @momentum/admin dev",
    "dev:all": "pnpm ensure:gpu && pnpm --parallel --filter \"@momentum/*\" dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @momentum/shared build",
    "build:server": "pnpm --filter @momentum/server build",
    "build:com": "pnpm --filter @momentum/com build",
    "build:team": "pnpm --filter @momentum/team build",
    "build:admin": "pnpm --filter @momentum/admin build",
    "typecheck": "pnpm -r typecheck",
    "catalog:persistence": "node server/scripts/generate-persistence-write-catalog.mjs",
    "catalog:persistence:check": "node server/scripts/generate-persistence-write-catalog.mjs --check",
    "catalog:schema": "node server/scripts/generate-schema-catalog.mjs",
    "catalog:schema:check": "node server/scripts/generate-schema-catalog.mjs --check",
    "catalog:schema-drift:check": "pnpm catalog:schema:check && pnpm catalog:mongo-ownership:check && pnpm catalog:mongo-indexes:check && pnpm catalog:neo4j:check && pnpm catalog:chroma:check",
    "catalog:mongo-ownership": "node server/scripts/generate-mongo-ownership-map.mjs",
    "catalog:mongo-ownership:check": "node server/scripts/generate-mongo-ownership-map.mjs --check",
    "catalog:mongo-indexes": "node server/scripts/generate-mongo-index-audit.mjs",
    "catalog:mongo-indexes:check": "node server/scripts/generate-mongo-index-audit.mjs --check",
    "catalog:neo4j": "node server/scripts/generate-neo4j-catalog.mjs",
    "catalog:neo4j:check": "node server/scripts/generate-neo4j-catalog.mjs --check",
    "catalog:chroma": "node server/scripts/generate-chroma-catalog.mjs",
    "catalog:chroma:check": "node server/scripts/generate-chroma-catalog.mjs --check",
    "catalog:generate:all": "pnpm catalog:schema && pnpm catalog:mongo-ownership && pnpm catalog:mongo-indexes && pnpm catalog:neo4j && pnpm catalog:chroma && pnpm catalog:persistence && pnpm catalog:api-routes && pnpm catalog:route-access && pnpm registry:build && pnpm docs:maps && pnpm compliance:com && pnpm docs:freshness",
    "catalog:api-routes": "node server/scripts/generate-api-route-map.mjs",
    "catalog:api-routes:check": "node server/scripts/generate-api-route-map.mjs --check",
    "catalog:route-access": "node server/scripts/generate-route-access-matrix.mjs",
    "catalog:route-access:check": "node server/scripts/generate-route-access-matrix.mjs --check",
    "registry:build": "node server/scripts/generate-build-registry.mjs",
    "registry:build:check": "node server/scripts/generate-build-registry.mjs --check",
    "docs:freshness": "node server/scripts/generate-doc-freshness-manifest.mjs",
    "docs:freshness:check": "node server/scripts/generate-doc-freshness-manifest.mjs --check",
    "docs:maps": "node server/scripts/generate-documentation-maps.mjs",
    "docs:maps:check": "node server/scripts/generate-documentation-maps.mjs --check",
    "memory:index": "node server/scripts/generate-memory-index.mjs",
    "memory:guard": "pnpm --filter @momentum/server exec tsx scripts/context-guard.ts",
    "memory:packet": "pnpm --filter @momentum/server exec tsx scripts/compile-context-packet.ts",
    "memory:verify": "pnpm --filter @momentum/server exec tsx scripts/verify-handle-retrieval.ts",
    "memory:populate-handles": "pnpm --filter @momentum/server exec tsx scripts/populate-context-handles.ts",
    "compliance:com": "node server/scripts/generate-com-prospect-compliance-scan.mjs",
    "compliance:com:check": "node server/scripts/generate-com-prospect-compliance-scan.mjs --check",
    "neo4j:schema:dry-run": "pnpm --filter @momentum/server neo4j:schema:dry-run",
    "neo4j:schema:apply": "pnpm --filter @momentum/server neo4j:schema:apply",
    "neo4j:schema:verify": "pnpm --filter @momentum/server neo4j:schema:verify",
    "docs": "node server/scripts/build-checklist.mjs && node server/scripts/sync-queue-from-wireframe.mjs",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "docx": "9.7.1",
    "ts-morph": "28.0.0",
    "typescript": "^5.5.4"
  }
}
