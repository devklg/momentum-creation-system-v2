{
  "name": "momentum-creation-system-v2",
  "private": true,
  "version": "0.0.0",
  "description": "Team Magnificent Marketing Momentum Creation System — three clients (.com prospect-facing, .team BA-facing, admin Kevin-only), one server, direct persistence.",
  "author": "Kevin L. Gardner",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "ensure:gpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-gpu-service.ps1",
    "dev": "pnpm ensure:gpu && pnpm --parallel --filter @momentum/team --filter @momentum/server dev",
    "dev:server": "pnpm ensure:gpu && pnpm --filter @momentum/server dev",
    "dev:com": "pnpm ensure:gpu && pnpm --filter @momentum/com dev",
    "dev:team": "pnpm ensure:gpu && pnpm --filter @momentum/team dev",
    "dev:admin": "pnpm ensure:gpu && pnpm --filter @momentum/admin dev",
    "dev:all": "pnpm ensure:gpu && pnpm --parallel --filter \"@momentum/*\" dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @momentum/shared build",
    "build:server": "pnpm --filter @momentum/server build",
    "build:com": "pnpm --filter @momentum/com build",
    "build:team": "pnpm --filter @momentum/team build",
    "build:admin": "pnpm --filter @momentum/admin build",
    "typecheck": "pnpm -r typecheck",
    "catalog:persistence": "node server/scripts/generate-persistence-write-catalog.mjs",
    "catalog:persistence:check": "node server/scripts/generate-persistence-write-catalog.mjs --check",
    "catalog:schema": "node server/scripts/generate-schema-catalog.mjs",
    "catalog:schema:check": "node server/scripts/generate-schema-catalog.mjs --check",
    "catalog:mongo-ownership": "node server/scripts/generate-mongo-ownership-map.mjs",
    "catalog:mongo-ownership:check": "node server/scripts/generate-mongo-ownership-map.mjs --check",
    "docs": "node server/scripts/build-checklist.mjs && node server/scripts/sync-queue-from-wireframe.mjs",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "docx": "9.7.1",
    "ts-morph": "28.0.0",
    "typescript": "^5.5.4"
  }
}
