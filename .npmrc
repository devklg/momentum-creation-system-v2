# pnpm settings for the Momentum Creation System monorepo

# Reject any other package manager (yarn, npm) from running install
# in this repo — keeps lockfile consistent.
engine-strict=true

# Save exact versions, not ranges.
save-exact=true

# Hoist workspace deps to root node_modules where safe.
# Strict mode keeps unrelated packages isolated, preventing phantom deps.
shamefully-hoist=false
strict-peer-dependencies=false

# Use the workspace protocol for cross-package deps (e.g. @momentum/shared).
link-workspace-packages=true
prefer-workspace-packages=true

# Don't run lifecycle scripts on install for packages we didn't author.
# (Manually allow per-package via `pnpm approve-builds` when needed.)
side-effects-cache=true
